{
  "name": "@numbered/activeframe-react",
  "version": "0.1.0",
  "description": "React wrapper for @numbered/activeframe — frame-accurate WebCodecs video.",
  "license": "MIT",
  "author": "luruke <lurukee@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Numbered-com/activeframe"
  },
  "homepage": "https://github.com/Numbered-com/activeframe",
  "bugs": {
    "url": "https://github.com/Numbered-com/activeframe/issues"
  },
  "keywords": ["video", "webcodecs", "activeframe", "react", "frame-accurate"],
  "type": "module",
  "files": ["dist"],
  "main": "dist/activeframe-react.js",
  "module": "dist/activeframe-react.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/activeframe-react.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "portless run vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^18.0.0 || >=19.0.0-0",
    "react-dom": "^18.0.0 || >=19.0.0-0"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "portless": "^0.12.0",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0"
  },
  "dependencies": {
    "@numbered/activeframe": "workspace:*"
  }
}
