{
  "name": "@numbered/activeframe-alpine",
  "version": "0.1.0",
  "description": "Alpine.js plugin for @numbered/activeframe — frame-accurate WebCodecs video.",
  "license": "MIT",
  "author": "luruke <lurukee@gmail.com>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Numbered-com/activeframe"
  },
  "homepage": "https://github.com/Numbered-com/activeframe",
  "bugs": {
    "url": "https://github.com/Numbered-com/activeframe/issues"
  },
  "keywords": ["video", "webcodecs", "activeframe", "alpine", "alpinejs"],
  "type": "module",
  "files": ["dist"],
  "main": "dist/activeframe-alpine.js",
  "module": "dist/activeframe-alpine.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/activeframe-alpine.js"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "dev": "portless run vite",
    "build": "vite build",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "alpinejs": "^3.0.0"
  },
  "devDependencies": {
    "@types/alpinejs": "^3.13.11",
    "alpinejs": "^3.15.12",
    "portless": "^0.12.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0"
  },
  "dependencies": {
    "@numbered/activeframe": "workspace:*"
  }
}
